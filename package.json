{
  "name": "community-captioner",
  "private": true,
  "version": "6.1.0",
  "type": "module",
  "main": "electron/main.js",
  "description": "AI-powered live captioning for community media.",
  "author": "Community Captioner",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amateurmenace/community-captioner-v10.git"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\"",
    "client": "vite",
    "build": "vite build",
    "server": "node server/relay.js",
    "start": "node server/relay.js",
    "build:native": "cmake-js build -d native/decklink",
    "dist": "npm run build && npm run build:native && electron-builder",
    "build:app": "node scripts/build-app.js",
    "build:mac": "node scripts/build-app.js --platform mac",
    "build:windows": "node scripts/build-app.js --platform win"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "@google/genai": "*",
    "cloudflared": "^0.7.1",
    "express": "^4.19.2",
    "lucide-react": "^0.378.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "recharts": "^2.12.7",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@yao-pkg/pkg": "^6.14.1",
    "autoprefixer": "^10.4.19",
    "cmake-js": "^8.0.0",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.27.4",
    "node-addon-api": "^8.6.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "build": {
    "appId": "com.community.captioner",
    "productName": "Community Captioner",
    "asar": false,
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "native/decklink/build/Release/*.node",
      "node_modules/ws/**/*",
      "node_modules/multer/**/*",
      "node_modules/pdf-parse/**/*",
      "node_modules/@google/genai/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "identity": "Stephen Walter (6M536MV7GT)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "notarize": {
        "teamId": "6M536MV7GT"
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
